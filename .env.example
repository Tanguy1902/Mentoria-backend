
# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- LLM Parameters ---
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --- Chunking ---
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# --- RAG ---
TOP_K_RESULTS=5

# --- Logging ---
LOG_LEVEL=INFO
